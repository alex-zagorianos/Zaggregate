# Scoped rules — the repo's core.autocrlf=true would otherwise let a fresh
# Windows checkout re-CRLF generated/built/binary payloads, breaking
# byte-reproducibility (tests/webui/test_tokens_gen.py asserts an exact byte
# match, and the committed built webui/static/ output is meant to be usable
# as-is without a Node rebuild). Deliberately NOT repo-wide — that would dirty
# every legacy file's line endings. Paths under src/ since the S43 restructure.

# The generated token sheet: always LF, always text.
src/webui/frontend/src/tokens.css text eol=lf

# Frontend source: force LF for text, but call out real binaries explicitly so
# `text=auto` never misdetects a font/image as text.
src/webui/frontend/** text=auto eol=lf
src/webui/frontend/**/*.woff binary
src/webui/frontend/**/*.woff2 binary
src/webui/frontend/**/*.png binary
src/webui/frontend/**/*.ico binary
src/webui/frontend/**/*.svg text eol=lf

# Built output (committed so source users without Node still get the web UI):
# built JS/CSS/HTML must stay LF; fonts/images stay binary.
src/webui/static/** text eol=lf
src/webui/static/**/*.woff binary
src/webui/static/**/*.woff2 binary
src/webui/static/**/*.png binary
src/webui/static/**/*.ico binary
src/webui/static/**/*.svg text eol=lf

# The in-repo runnable app (Executables/): store byte-for-byte, never
# eol-normalize — a GitHub Code->Download ZIP must deliver exactly the bytes
# PyInstaller produced (tcl/tzdata/encoding data files are eol-sensitive).
Executables/** -text
