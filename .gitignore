# === SECRETS & CREDENTIALS ===
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
# Exception: the REAP portals' PUBLIC Sectigo intermediate CA cert (NOT a secret
# — it is a publicly-distributed CA certificate). It must SHIP so search/
# reap_client.py can complete those servers' incomplete TLS chain. See the file's
# own header for why. This is the only *.pem that is intentionally tracked.
!data_static/reap_sectigo_r36_intermediate.pem
secrets/
credentials/

# === CACHE & GENERATED OUTPUT ===
cache/
output/
# per-run job_key baselines (search/freshness.py) + tiered-scrape state
# (scrape/tiering.py) — runtime state like cache/, not source.
freshness/
registry_state.json

# === PYTHON ===
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
# The ready-to-run production/ folder assembled by `build_package.py --production`
# (exe + runtime files + extension). Like dist/, it is a BUILD ARTIFACT — the
# script + app.spec are the reproducibility anchor, not the folder.
production/
*.spec
!app.spec
.pytest_cache/
.mypy_cache/
.ruff_cache/

# === FRONTEND (webui/frontend Vite app) ===
# node_modules is transient; reinstall with `npm install`. The BUILT output
# (webui/static/) is intentionally COMMITTED so source users without Node still
# get the web UI — do NOT ignore it.
webui/frontend/node_modules/
# Vite's local build caches / tsbuildinfo
webui/frontend/.vite/
webui/frontend/**/*.tsbuildinfo

# === VIRTUAL ENVIRONMENTS ===
venv/
.venv/
env/
ENV/

# === OS & EDITOR ===
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# === TRACKER ===
tracker.db

# === PERSONAL CONFIG (sanitized template lives in config.example.json) ===
legacy/config_dad.json
/user_config.json
# User data scaffolded from data_templates/ (root only; keep the templates tracked)
/preferences.md
/preferences.json
# Personal career master file (PII: address/phone) — template lives in data_templates/
/experience.md
# First-run Setup wizard marker (per-user state, like tracker.db)
/.onboarded
# First-run sample-inbox retirement marker (per-user state; §6.1)
/.demo_inbox_retired
# Per-user UI preferences (light/dark theme choice)
/ui_settings.json
# Imported referral network (LinkedIn/Google contacts) — USER-LEVEL data under
# USER_DATA_DIR (= repo root in dev). PII (names/companies); never commit. (B4)
/network.json

# === PROJECT WORKSPACES (local: per-project config/resume/tracker.db/output) ===
projects/
*.bak

# === LOGS & RUN STATE ===
*.log
logs/
# Rolling tracker.db backups + machine-readable run beacon (dev checkout runs
# write these at the repo root, since USER_DATA_DIR = repo root in dev).
backups/
last_run.json

# Claude Code agent worktrees (transient; created per builder run) + reach run data
.claude/worktrees/
coverage/reach/

# === LOCAL SCAFFOLDING & PERSONAL STRATEGY (kept local; not part of the distributable) ===
legacy/candidates.json
legacy/flatten_candidates.py
legacy/verify_and_add.py
/legacy/job search/

# graphify knowledge graph (local artifact, rebuild via graphify update .)
graphify-out/
