# Adzuna API (Phase 1) — Get keys at https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# Anthropic API (Phase 2 — resume generator) — Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Brave Search API (optional — enables company auto-discovery, free 2,000 req/month)
# Sign up at https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=your_brave_key_here

# JSearch via RapidAPI — aggregates Indeed, LinkedIn, Glassdoor (200 req/month free)
# Get key at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_RAPIDAPI_KEY=your_rapidapi_key_here

# USAJobs API — federal job board (free, requires registration)
# Get a free key at https://developer.usajobs.gov/apirequest/
USAJOBS_API_KEY=your_usajobs_key_here
USAJOBS_USER_AGENT=your_email@example.com

# CareerOneStop (US DOL / NLx) — the best free source for non-tech / on-site jobs
# (nurses, teachers, government, trades, retail): ~3.5M US postings/day from all
# 50 state job banks. In our tests this supplied the local jobs the built-in feeds
# missed. Free key (userId + token): register at
# https://www.careeronestop.org/Developers/WebAPI/registration.aspx
# NOTE: the CareerOneStop *Jobs* API is governance-gated (since 2024-08-27) — you
# may need to request Jobs-API access separately after registering; the rest of
# the CareerOneStop API family is self-serve. THIS SAME KEY also powers "Seed my
# area" (Tools ▸ Seed my area), which uses CareerOneStop's Business Finder
# employer directory (self-serve) to find local employers with live careers boards
# — so one free key unlocks both the job feed AND local-employer seeding.
CAREERONESTOP_USER_ID=your_careeronestop_user_id_here
CAREERONESTOP_TOKEN=your_careeronestop_token_here

# Jooble — free aggregator API key; adds local postings the others miss.
# Request a key at https://jooble.org/api/about
JOOBLE_API_KEY=your_jooble_key_here

# Careerjet — free affiliate ID; another aggregator that adds unique postings.
# Get a free affiliate ID at https://www.careerjet.com/partners/publishers/
CAREERJET_AFFID=your_careerjet_affid_here

# SerpApi (optional, BYO) — a Google-Jobs backend that also powers the Inbox
# "reach" badge (the capture-recapture probe that estimates what % of your local
# market the app is actually seeing). A small free quota (250 searches/month) is
# plenty. Get a key at https://serpapi.com/  (or drop it in secrets/serpapi_key).
SERPAPI_KEY=your_serpapi_key_here
